{
  "include": [
    "src/**/*"
  ],
  "compilerOptions": {
    "rootDir": "src",
    "target": "ES2020",
    "module": "node16",
    "moduleResolution": "node16",
    "declaration": true,
    "outDir": "dist",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "allowJs": true,
    "resolveJsonModule": true,
  }
}
